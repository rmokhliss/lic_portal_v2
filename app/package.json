    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/infrastructure/db/migrate.ts",
    "db:seed": "tsx --conditions=react-server src/server/infrastructure/db/seed.ts",
