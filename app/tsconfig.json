{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@/shared/*": ["./shared/src/*"],
      "@s2m-lic/shared": ["./shared/src/index.ts"],
      "@s2m-lic/shared/*": ["./shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "src/app/.well-known/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", "coverage", "playwright-report"]
}
