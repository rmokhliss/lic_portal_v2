# ==============================================================================
# LIC v2 — variables d'environnement (template)
#
# Copier ce fichier en .env (jamais commité) et remplir les valeurs.
# Validé par app/src/server/infrastructure/env/ (Zod) au démarrage.
# ==============================================================================

# --- Application --------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# --- Branding produit (Référentiel §4.4) --------------------------------------
NEXT_PUBLIC_PRODUCT_CODE=LIC
NEXT_PUBLIC_PRODUCT_NAME=Licence Manager
NEXT_PUBLIC_PRODUCT_SUFFIX=PORTAL

# --- PostgreSQL ---------------------------------------------------------------
# Local Docker : voir docker-compose.yml
DATABASE_URL=postgresql://lic_portal:lic_portal_dev@localhost:5432/lic_portal
DATABASE_POOL_SIZE=10

# --- Auth.js v5 ---------------------------------------------------------------
# Générer avec : openssl rand -base64 32
AUTH_SECRET=__TO_GENERATE__
AUTH_TRUST_HOST=true

# --- Crypto / PKI (clé maîtresse de chiffrement au repos en BD) --------------
# Clé AES-256 (32 octets en base64) qui chiffre les clés privées RSA stockées
# en BD (CA S2M + paire RSA par client). NE JAMAIS PERDRE NI CHANGER après
# initialisation des données. Générer avec : openssl rand -base64 32
APP_MASTER_KEY=__TO_GENERATE__

# --- SMTP (Référentiel §4.4 + DETTE-003) --------------------------------------
# Si SMTP_HOST absent : mode simulé (logs Pino "Email simulé"), pas d'erreur
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Licence Manager <noreply@s2m.ma>"
SMTP_SECURE=false

# --- Logging Pino -------------------------------------------------------------
LOG_LEVEL=info
# Options : trace | debug | info | warn | error | fatal
# En dev : "debug" recommandé. En prod : "info".

# --- pg-boss (Référentiel §1.4 — pas de Redis) --------------------------------
# Worker pg-boss tourne dans un process séparé via "pnpm worker:dev"
# Utilise DATABASE_URL pour ses tables internes (pg_boss schema)

# --- i18n ---------------------------------------------------------------------
DEFAULT_LOCALE=fr

# --- Endpoint public clé CA (toggle ADR-0002) ---------------------------------
# true  : /.well-known/s2m-ca.pem accessible publiquement
# false : route 404
EXPOSE_S2M_CA_PUBLIC=false

# --- Build SHA (Phase 13.C, DETTE-LIC-007) -----------------------------------
# Version courte du commit injectée par CI au build. Affichée dans /settings/info.
# Fallback "dev" en local. BUILD_SHA est uniquement utilisé au build (pnpm build),
# pas en runtime — pas besoin de la définir dans .env, c'est fait via env var
# au build CI (.github/workflows/ci.yml) ou via Docker --build-arg BUILD_SHA=...

# --- OpenTelemetry (Référentiel §1.2) -----------------------------------------
# Optionnel en dev. Configurer en prod.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=s2m-lic

# --- Bootstrap admin initial (F-07) -------------------------------------------
# Crée un compte SADMIN au premier démarrage si aucun n'existe encore en BD.
# TOUT-OU-RIEN : décommenter les 3 lignes ensemble. Le mot de passe doit faire
# >=12 chars. Au login : must_change_password=true -> flow obligatoire.
# Format matricule : MAT-NNN (3 chiffres).
# INITIAL_ADMIN_EMAIL=admin@s2m.ma
# INITIAL_ADMIN_PASSWORD=__MIN_12_CHARS__
# INITIAL_ADMIN_MATRICULE=MAT-001
